{
  "ConnectionStrings": {
    "DefaultConnection": "DefaultConnectionFromUserSecrets"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "SecurityKey": "SecurityKeyFromUserSecrets",
    "Issuer": "IssuerFromUserSecrets",
    "Audience": "AudienceFromUserSecrets",
    "ExpiryInMinutes": 60
  },
  "Google": {
    "ClientId": "ClientIdFromUserSecrets",
    "ClientSecret": "ClientSecretFromUserSecrets"
  },
  "SeedData": {
    "AdminEmail": "admin@example.com",
    "AdminPassword": "PlaceholderPassword123!",
    "ManagerPassword": "PlaceholderPassword123!"
  },
  "AllowedHosts": "*"
}
